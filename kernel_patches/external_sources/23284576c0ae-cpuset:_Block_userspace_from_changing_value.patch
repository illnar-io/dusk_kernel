From 23284576c0ae48918385120c181902ba7e4e3cc7 Mon Sep 17 00:00:00 2001
From: "M. \"Harumajati\" Alfarozi" <reinazhard@gmail.com>
Date: Sat, 28 Feb 2026 18:19:09 +0700
Subject: [PATCH] cpuset: Block userspace from changing value

Let the kernel manage the tasks

Signed-off-by: M. "Harumajati" Alfarozi <reinazhard@gmail.com>
---
 kernel/cgroup/cpuset.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/kernel/cgroup/cpuset.c b/kernel/cgroup/cpuset.c
index 50edbac68..684386216 100644
--- a/kernel/cgroup/cpuset.c
+++ b/kernel/cgroup/cpuset.c
@@ -84,6 +84,8 @@ DEFINE_STATIC_KEY_FALSE(cpusets_insane_config_key);
 
 /* See "Frequency meter" comments, below. */
 
+static bool cpuset_userspace_readonly = true;
+
 struct fmeter {
 	int cnt;		/* unprocessed events count */
 	int val;		/* most recent output value */
@@ -2816,6 +2818,9 @@ static int cpuset_write_u64(struct cgroup_subsys_state *css, struct cftype *cft,
 	cpuset_filetype_t type = cft->private;
 	int retval = 0;
 
+	if (cpuset_userspace_readonly)
+		return 0;
+
 	cpus_read_lock();
 	mutex_lock(&cpuset_mutex);
 	if (!is_cpuset_online(cs)) {
@@ -2865,6 +2870,9 @@ static int cpuset_write_s64(struct cgroup_subsys_state *css, struct cftype *cft,
 	cpuset_filetype_t type = cft->private;
 	int retval = -ENODEV;
 
+	if (cpuset_userspace_readonly)
+		return 0;
+
 	cpus_read_lock();
 	mutex_lock(&cpuset_mutex);
 	if (!is_cpuset_online(cs))
@@ -2894,6 +2902,9 @@ static ssize_t cpuset_write_resmask(struct kernfs_open_file *of,
 	struct cpuset *trialcs;
 	int retval = -ENODEV;
 
+	if (cpuset_userspace_readonly)
+		return nbytes;
+
 	buf = strstrip(buf);
 
 	/*
@@ -3076,6 +3087,9 @@ static ssize_t sched_partition_write(struct kernfs_open_file *of, char *buf,
 	int val;
 	int retval = -ENODEV;
 
+	if (cpuset_userspace_readonly)
+		return nbytes;
+
 	buf = strstrip(buf);
 
 	/*
-- 
2.54.0

