From 67fe1061b2c26bf550151b07f89a26d6d63f4be7 Mon Sep 17 00:00:00 2001
From: Sultan Alsawaf <sultan@kerneltoast.com>
Date: Sun, 25 Jun 2023 22:22:50 -0700
Subject: [PATCH] pcie: exynos: Memoize ep_l1ss_cap_off as an optimization

The preemptoff tracer shows that the dw_pcie_read() call invoked by
pci_find_ext_capability() may take up to 4000 us sometimes, which is
absurdly long. To avoid the latency overhead from this where possible, just
memoize ep_l1ss_cap_off the first time the PCIe device is enabled so that
it doesn't need to be constantly reread.

Signed-off-by: Sultan Alsawaf <sultan@kerneltoast.com>
---
 .../gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c   | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c b/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c
index 0c632d46d..419e39b41 100644
--- a/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c
+++ b/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c
@@ -4035,6 +4035,10 @@ int exynos_pcie_rc_poweron(int ch_num)
 		}
 	}
 
+	if (exynos_pcie->ep_l1ss_cap_off == U32_MAX)
+		WRITE_ONCE(exynos_pcie->ep_l1ss_cap_off,
+			   pci_find_ext_capability(exynos_pcie->ep_pci_dev, PCI_EXT_CAP_ID_L1SS));
+
 	dev_dbg(dev, "end poweron, state: %d\n", exynos_pcie->state);
 	logbuffer_log(exynos_pcie->log, "end poweron, state: %d\n", exynos_pcie->state);
 	mutex_unlock(&exynos_pcie->power_onoff_lock);
@@ -4386,10 +4390,10 @@ static int exynos_pcie_rc_set_l1ss(int enable, struct dw_pcie_rp *pp, int id)
 		dev_dbg(dev, "%s:state = 0x%x, id = 0x%x: not needed(This will be set later)\n",
 			__func__, exynos_pcie->l1ss_ctrl_id_state, id);
 
+		return -1;
+	} else if (READ_ONCE(exynos_pcie->ep_l1ss_cap_off) == U32_MAX) {
 		return -1;
 	} else {
-		exynos_pcie->ep_l1ss_cap_off =
-			pci_find_ext_capability(exynos_pcie->ep_pci_dev, PCI_EXT_CAP_ID_L1SS);
 		exynos_pcie->ep_link_ctrl_off = exynos_pcie->ep_pci_dev->pcie_cap + PCI_EXP_LNKCTL;
 		exynos_pcie->ep_l1ss_ctrl1_off = exynos_pcie->ep_l1ss_cap_off + PCI_L1SS_CTL1;
 		exynos_pcie->ep_l1ss_ctrl2_off = exynos_pcie->ep_l1ss_cap_off + PCI_L1SS_CTL2;
@@ -5803,6 +5807,7 @@ static int exynos_pcie_rc_probe(struct platform_device *pdev)
 	pp = &pci->pp;
 	pp->ops = &exynos_pcie_rc_ops;
 
+	exynos_pcie->ep_l1ss_cap_off = U32_MAX;
 	spin_lock_init(&exynos_pcie->pcie_l1_exit_lock);
 	spin_lock_init(&exynos_pcie->conf_lock);
 	spin_lock_init(&exynos_pcie->power_stats_lock);
-- 
