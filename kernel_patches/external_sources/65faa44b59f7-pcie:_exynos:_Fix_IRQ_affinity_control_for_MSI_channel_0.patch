From 65faa44b59f7e1f8c0c163e7f2498b36b4c96b83 Mon Sep 17 00:00:00 2001
From: Sultan Alsawaf <sultan@kerneltoast.com>
Date: Sun, 23 Jul 2023 21:50:42 -0700
Subject: [PATCH] pcie: exynos: Fix IRQ affinity control for MSI channel 0

Ironically, the check for MSI channel 0 in exynos_pcie_msi_set_affinity()
actually prevents the modem driver from controlling MSI channel 0's
affinity, since the modem driver just sets IRQ affinity through the normal
IRQ affinity interface. Remove this check to allow MSI channel 0 to be
freely affined by the modem driver or anything else.

Signed-off-by: Sultan Alsawaf <sultan@kerneltoast.com>
---
 .../soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c    | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c b/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c
index 6dfcecaaa..a41f0c73a 100644
--- a/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c
+++ b/google-modules/soc/gs/drivers/pci/controller/dwc-whi/pcie-exynos-rc.c
@@ -5157,10 +5157,6 @@ static int exynos_pcie_msi_set_affinity(struct irq_data *irq_data, const struct
 	if (!exynos_pcie)
 		return -ENODEV;
 
-	/* modem driver sets msi irq affinity */
-	if (exynos_pcie->ch_num == 0)
-		return 0;
-
 	idata = irq_get_irq_data(pp->irq);
 	if (!idata || !idata->chip)
 		return -ENODEV;
-- 
2.54.0

