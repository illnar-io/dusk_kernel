From 51e2fb0df8d83ef14c9d9613f9e60c8f3ec52a31 Mon Sep 17 00:00:00 2001
From: freak07 <michalechner92@googlemail.com>
Date: Tue, 1 Nov 2022 13:38:27 +0100
Subject: [PATCH] gs201: change control_temp_step to reduce overshoot
 throttling

as in https://android.googlesource.com/kernel/gs/+/255c38af8e7835b5b069f334d68cb11ff2254643

Signed-off-by: acuicultor <ramoncuenca4@gmail.com>

# Conflicts:
#	arch/arm64/boot/dts/google/gs201-b0.dts
---
 arch/arm64/boot/dts/google/gs201-b0.dts | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/google/gs201-b0.dts b/arch/arm64/boot/dts/google/gs201-b0.dts
index 251c232fba72..3816cb4fc241 100644
--- a/arch/arm64/boot/dts/google/gs201-b0.dts
+++ b/arch/arm64/boot/dts/google/gs201-b0.dts
@@ -168,7 +168,7 @@
 		i_max = <2>;
 		integral_cutoff = <10>;
 		sustainable_power = <2000>;
-		control_temp_step = <100>;
+		control_temp_step = <50>;
 
 		tmu_work_affinity = "0-7";
 		hotplug_work_affinity = "0-3";
@@ -194,7 +194,7 @@
 		i_max = <5>;
 		integral_cutoff = <20>;
 		sustainable_power = <1000>;
-		control_temp_step = <100>;
+		control_temp_step = <50>;
 
 		tmu_work_affinity = "0-7";
 		hotplug_work_affinity = "0-3";
@@ -241,7 +241,7 @@
 		i_max = <5>;
 		integral_cutoff = <20>;
 		sustainable_power = <200>;
-		control_temp_step = <100>;
+		control_temp_step = <50>;
 
 		tmu_work_affinity = "0-7";
 		has-dfs-support;
@@ -277,7 +277,7 @@
 		i_max = <5>;
 		integral_cutoff = <20>;
 		sustainable_power = <200>;
-		control_temp_step = <100>;
+		control_temp_step = <50>;
 
 		tmu_work_affinity = "0-7";
 		has-dfs-support;
