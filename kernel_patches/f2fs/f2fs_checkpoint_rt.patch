--- a/fs/f2fs/checkpoint.c
+++ b/fs/f2fs/checkpoint.c
@@ -2124,6 +2124,11 @@ int f2fs_start_ckpt_thread(struct f2fs_sb_info *sbi)
 	set_task_ioprio(cprc->f2fs_issue_ckpt, cprc->ckpt_thread_ioprio);
 	set_user_nice(cprc->f2fs_issue_ckpt,
 			PRIO_TO_NICE(sbi->critical_task_priority));
+
+	// Set checkpoint thread to realtime scheduling to avoid stalls during heavy I/O
+	struct sched_param param = { .sched_priority = 80 };
+	sched_setscheduler(cprc->f2fs_issue_ckpt, SCHED_FIFO, &param);
+
 	return 0;
 }
